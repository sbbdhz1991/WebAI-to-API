# =============================================================================
# WebAI-to-API — environment template
# =============================================================================
# Copy to .env and fill in. docker-compose reads this file (web_ai via
# env_file, plus ${VAR} interpolation for chrome_server). All values are
# optional unless noted; empty = the documented default.
#
#   cp .env.example .env
#
# .env holds live secrets (API key, proxy creds, VNC password) — keep it out
# of git.
# =============================================================================

# ---------------------------------------------------------------------------
# API authentication
# ---------------------------------------------------------------------------
# Shared secret clients must present (Authorization: Bearer <key>, or
# x-api-key / x-goog-api-key / ?key=). EMPTY = auth DISABLED (anyone who can
# reach :6969 can use it). Set a long random value in production.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Deploy / network
# ---------------------------------------------------------------------------
# production | development. development also loads docker-compose.override.yml
# (source bind-mount + hot sync).
ENVIRONMENT=production

# Name of the EXTERNAL docker network both containers join. Must already
# exist (e.g. 1panel's network). Default: 1panel-network.
DOCKER_NETWORK=1panel-network

# ---------------------------------------------------------------------------
# Chrome sidecar — noVNC login UI
# ---------------------------------------------------------------------------
# Password for the noVNC desktop (http://127.0.0.1:6080/vnc.html) used for
# the one-time Google login. The VNC protocol TRUNCATES this to 8 chars, so
# it only stops drive-by scans — put noVNC behind a reverse proxy with real
# auth / IP allowlist for actual protection. Empty = NO password (open).
VNC_PASSWORD=

# ---------------------------------------------------------------------------
# Outbound proxy for the Chrome session (login + DBSC rotation)
# ---------------------------------------------------------------------------
# Routing the Google session through a clean / residential exit IP is the
# biggest lever against Google revoking a session it sees coming from a
# datacenter IP. Use a STABLE IP in the account's usual region — a
# rotating-IP proxy makes things WORSE. Set at most ONE of the two:
#
#   PROXY_SERVER   — proxy that needs NO auth (IP-whitelisted). Chromium
#                    points straight at it.
#   PROXY_UPSTREAM — proxy that needs user:pass. An in-container tinyproxy
#                    bridges it for headless Chromium (which can't answer a
#                    proxy auth dialog). Takes precedence over PROXY_SERVER.
#
# Format (scheme = http | https | socks5 | socks4):
#   PROXY_SERVER=http://10.0.0.5:8080
#   PROXY_SERVER=socks5://10.0.0.5:1080
#   PROXY_UPSTREAM=http://user:pass@host:port
#   PROXY_UPSTREAM=socks5://user:pass@host:port
#
# After changing either, rebuild chrome_server and RE-LOGIN via noVNC so the
# Google session is established from the new exit IP.
PROXY_SERVER=
PROXY_UPSTREAM=

# ---------------------------------------------------------------------------
# Tuning / diagnostics (rarely changed)
# ---------------------------------------------------------------------------
# Session health-probe interval, seconds. The probe is passive (reads the
# cookie jar, no outbound Google traffic), so this is only a detection-latency
# knob. 0 = disable monitoring. Default 300.
CHROME_KEEPALIVE_INTERVAL=300

# Override gemini-webapi's 120s stream-idle watchdog (seconds). Bump if long
# media analyses time out. 0 = keep library default.
WEBAI_WATCHDOG_TIMEOUT=0

# 1/true = dump the full outgoing StreamGenerate request (URL+headers+cookies)
# at WARN level for one-off debugging. SENSITIVE (logs live cookies). Default
# off.
WEBAI_DEBUG_DUMP_REQUEST=
