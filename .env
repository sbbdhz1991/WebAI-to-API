ENVIRONMENT=development
# ENVIRONMENT=production

# API key for authenticating requests to the WebAI-to-API server.
# Leave empty to disable authentication (all endpoints open).
# When set, clients must pass this key via:
#   Authorization: Bearer <key>  |  x-goog-api-key: <key>  |  x-api-key: <key>  |  ?key=<key>
GEMINI_API_KEY=

# Name of an EXISTING external Docker network to attach the container to.
# Default 1panel-network targets 1Panel's default user-defined bridge.
# The network must already exist (`docker network ls` to verify).
DOCKER_NETWORK=1panel-network