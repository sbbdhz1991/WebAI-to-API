ENVIRONMENT=development
# ENVIRONMENT=production

# API key for authenticating requests to the WebAI-to-API server.
# Leave empty to disable authentication (all endpoints open).
# When set, clients must pass this key via:
#   Authorization: Bearer <key>  |  x-goog-api-key: <key>  |  x-api-key: <key>  |  ?key=<key>
GEMINI_API_KEY=